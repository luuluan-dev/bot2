<h1 class="text-2xl font-semibold text-gray-700 mb-4">Cài đặt</h1>
<form class="space-y-4">
    <div class="grid grid-cols-2 gap-4">
        <div>
            <label class="block text-gray-600" for="channel_spam_bot">AI Channel ID</label>
            <input type="text" id="channel_spam_bot" name="channel_spam_bot" class="w-full p-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" onchange="saveSetting(event)" value="<%=settings.channel_spam_bot || '' %>" />
        </div>
        <div>
            <label class="block text-gray-600" for="electric_target_id">Chích điện người này</label>
            <input type="text" id="electric_target_id" name="electric_target_id" class="w-full p-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" value="<%=settings.electric_target_id || '' %>" onchange="saveSetting(event)">
        </div>
        <div>
            <label class="block text-gray-600" for="ai_model">Gemini Model</label>
            <input type="text" id="ai_model" name="ai_model" class="w-full p-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" value="<%=settings.ai_model || '' %>" onchange="saveSetting(event)">
        </div>
    </div>
</form>

<!-- Public Pages -->
<div class="mt-8">
    <h2 class="text-lg font-semibold text-gray-700 mb-3">Trang công khai (không cần đăng nhập)</h2>
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 uppercase text-xs">
                <tr>
                    <th class="px-4 py-3 text-left">Trang</th>
                    <th class="px-4 py-3 text-left">Công khai</th>
                    <th class="px-4 py-3 text-left">Passkey (để trống = không cần)</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <% configurablePages.forEach(function(page) { %>
                <tr>
                    <td class="px-4 py-3 font-medium text-gray-700"><%= page.label %></td>
                    <td class="px-4 py-3">
                        <input type="checkbox"
                            id="public-<%= page.key %>"
                            value="<%= page.key %>"
                            onchange="savePublicPages()"
                            <%= (settings.public_pages || '').split(',').map(s => s.trim()).includes(page.key) ? 'checked' : '' %>
                            class="w-4 h-4 accent-blue-500">
                    </td>
                    <td class="px-4 py-3">
                        <input type="password"
                            id="passkey-<%= page.key %>"
                            placeholder="Passkey..."
                            value="<%= settings['passkey_' + page.key] || '' %>"
                            onchange="savePasskey('<%= page.key %>', this.value)"
                            class="p-1.5 border border-gray-300 rounded text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 w-48">
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- contentFor('scripts') %>
<script>
    async function savePasskey(pageKey, value) {
        const res = await fetch('/settings/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key: `passkey_${pageKey}`, value })
        });
        if (res.ok) showToast('Đã lưu passkey');
        else showToast('Có lỗi xảy ra');
    }

    async function savePublicPages() {
        const checked = Array.from(document.querySelectorAll('input[id^="public-"]:checked'))
            .map(el => el.value).join(',');
        const res = await fetch('/settings/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key: 'public_pages', value: checked })
        });
        if (res.ok) {
            showToast('Đã cập nhật trang công khai');
        } else {
            showToast('Có lỗi xảy ra');
        }
    }

    async function saveSetting(event) {
        const saved = await fetch('/settings/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                key: event.target.name,
                value: event.target.value
            })
        });
        if (saved.ok) {
            showToast('Cài đặt đã được lưu');
        } else {
            showToast('Có lỗi xảy ra, vui lòng thử lại sau');
        }
    }
</script>
