<h1 class="text-2xl font-semibold text-gray-700 mb-6">📋 Dashboard</h1>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <!-- Prefix Commands -->
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
        <div class="bg-gray-50 px-4 py-3 border-b border-gray-200">
            <h2 class="font-semibold text-gray-700">⚡ Lệnh prefix <span class="text-gray-400 font-mono text-sm">!cmd</span></h2>
        </div>
        <div class="divide-y divide-gray-50">
            <% commands.forEach(function(cmd) { %>
            <div class="px-4 py-3 flex items-start gap-3">
                <span class="font-mono text-blue-600 text-sm bg-blue-50 px-2 py-0.5 rounded shrink-0">!<%= cmd.name %></span>
                <span class="text-gray-600 text-sm"><%= cmd.description %></span>
            </div>
            <% }) %>
        </div>
    </div>

    <!-- Slash Commands -->
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
        <div class="bg-gray-50 px-4 py-3 border-b border-gray-200">
            <h2 class="font-semibold text-gray-700">✨ Slash commands <span class="text-gray-400 font-mono text-sm">/cmd</span></h2>
        </div>
        <div class="divide-y divide-gray-50">
            <% slashCommands.forEach(function(cmd) { %>
            <div class="px-4 py-3 flex items-start gap-3">
                <span class="font-mono text-purple-600 text-sm bg-purple-50 px-2 py-0.5 rounded shrink-0">/<%= cmd.name %></span>
                <span class="text-gray-600 text-sm"><%= cmd.description %></span>
            </div>
            <% }) %>
        </div>
    </div>

</div>
