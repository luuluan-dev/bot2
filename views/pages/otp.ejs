<h1 class="text-2xl font-semibold text-gray-700 mb-6">🔐 OTP Secrets</h1>

<% const isGuest = !currentUser || currentUser.role === 'GUEST'; %>

<div class="bg-white border border-gray-200 rounded-lg overflow-hidden mb-4">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-500 uppercase text-xs">
            <tr>
                <th class="px-4 py-3 text-left">Name</th>
                <th class="px-4 py-3 text-left">Secret Key</th>
                <% if (!isGuest) { %>
                <th class="px-4 py-3 text-left">Share Passkey</th>
                <th class="px-4 py-3 text-right">Hành động</th>
                <% } %>
            </tr>
        </thead>
        <tbody id="otp-table-body">
            <% if (otpSecrets.length === 0) { %>
            <tr id="otp-empty-row">
                <td colspan="<%= isGuest ? 2 : 4 %>" class="px-4 py-4 text-center text-gray-400">Chưa có OTP secret nào</td>
            </tr>
            <% } %>
            <% otpSecrets.forEach(function(otp) { %>
            <tr class="border-t border-gray-100" id="otp-row-<%=otp.id%>">
                <td class="px-4 py-3 font-medium text-gray-700"><%=otp.name%></td>
                <% if (!isGuest) { %>
                <td class="px-4 py-3 font-mono">
                    <span id="otp-val-<%=otp.id%>" data-secret="<%=otp.value%>" class="text-gray-400">••••••••••••••••</span>
                </td>
                <td class="px-4 py-3">
                    <input type="password" placeholder="Passkey share..."
                        value="<%=otp.sharePasskey || ''%>"
                        onchange="saveSharePasskey('<%=otp.id%>', this.value)"
                        class="p-1.5 border border-gray-300 rounded text-xs focus:outline-none focus:ring-2 focus:ring-blue-400 w-36">
                </td>
                <td class="px-4 py-3 text-right flex items-center justify-end gap-1">
                    <button onclick="toggleSecret('<%=otp.id%>')" id="otp-eye-<%=otp.id%>" title="Hiện/Ẩn" class="text-gray-400 hover:text-gray-600 text-xs px-2 py-1 rounded hover:bg-gray-100 transition">👁</button>
                    <button onclick="getOtp('<%=otp.id%>', <%=!!otp.sharePasskey%>)" title="Lấy mã OTP" class="text-blue-400 hover:text-blue-600 text-xs px-2 py-1 rounded hover:bg-blue-50 transition font-medium">OTP</button>
                    <button onclick="shareOtp('<%=otp.id%>', '<%=otp.shareToken || ''%>')" title="Share URL" class="text-green-400 hover:text-green-600 text-xs px-2 py-1 rounded hover:bg-green-50 transition">🔗</button>
                    <button onclick="deleteOtp('<%=otp.id%>')" class="text-red-400 hover:text-red-600 text-xs px-2 py-1 rounded hover:bg-red-50 transition">Xóa</button>
                </td>
                <% } else { %>
                <td class="px-4 py-3 font-mono text-gray-500"><%=otp.value.replace(/\s/g,'').substring(0,4)%>••••••••••••</td>
                <% } %>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<!-- Add OTP Form (tất cả đều thêm được) -->
<div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
    <h3 class="text-sm font-semibold text-gray-600 mb-3">Thêm OTP Secret</h3>
    <div class="flex gap-3 items-end">
        <div class="flex-1">
            <label class="block text-xs text-gray-500 mb-1">Name</label>
            <input type="text" id="otp-new-name" placeholder="gmail" class="w-full p-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div class="flex-1">
            <label class="block text-xs text-gray-500 mb-1">Secret Key (Base32)</label>
            <input type="password" id="otp-new-value" placeholder="JBSW Y3DP EHPK 3PXP..." class="w-full p-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <button onclick="addOtp()" class="px-4 py-2 bg-blue-500 text-white rounded-lg text-sm hover:bg-blue-600 transition whitespace-nowrap">Thêm</button>
    </div>
</div>

<!-- Passkey modal cho guest -->
<div id="passkey-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-lg p-6 w-80">
        <h3 class="font-semibold text-gray-700 mb-4">🔑 Nhập passkey để lấy OTP</h3>
        <input type="password" id="modal-passkey-input" placeholder="Passkey..." class="w-full p-2 border border-gray-300 rounded-lg text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <div class="flex gap-2">
            <button onclick="submitPasskey()" class="flex-1 bg-blue-500 text-white py-2 rounded-lg text-sm hover:bg-blue-600 transition">Xác nhận</button>
            <button onclick="closePasskeyModal()" class="flex-1 bg-gray-100 text-gray-600 py-2 rounded-lg text-sm hover:bg-gray-200 transition">Hủy</button>
        </div>
    </div>
</div>

<%- contentFor('scripts') %>
<script>
    let _pendingOtpId = null;

    async function getOtp(id, needPasskey) {
        if (needPasskey) {
            _pendingOtpId = id;
            document.getElementById('modal-passkey-input').value = '';
            document.getElementById('passkey-modal').classList.remove('hidden');
            setTimeout(() => document.getElementById('modal-passkey-input').focus(), 50);
            return;
        }
        const res = await fetch(`/settings/otp/${id}/generate`);
        const data = await res.json();
        if (res.ok) showToast(`🔐 ${data.code}  ⏱ ${data.secondsRemaining}s`, 5000);
        else showToast(data.message || 'Lỗi khi lấy OTP');
    }

    async function submitPasskey() {
        const passkey = document.getElementById('modal-passkey-input').value;
        closePasskeyModal();
        const res = await fetch(`/otp/${_pendingOtpId}/verify-passkey`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ passkey })
        });
        const data = await res.json();
        if (res.ok) showToast(`🔐 ${data.code}  ⏱ ${data.secondsRemaining}s`, 5000);
        else showToast(data.message || 'Passkey không đúng');
    }

    function closePasskeyModal() {
        document.getElementById('passkey-modal').classList.add('hidden');
        _pendingOtpId = null;
    }

    document.getElementById('modal-passkey-input')?.addEventListener('keydown', e => {
        if (e.key === 'Enter') submitPasskey();
        if (e.key === 'Escape') closePasskeyModal();
    });

    async function saveSharePasskey(id, value) {
        await fetch(`/otp/${id}/share-passkey`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ passkey: value })
        });
        showToast('Đã lưu passkey share');
    }

    async function shareOtp(id, existingToken) {
        if (existingToken) {
            const url = `${location.origin}/otp/share/${existingToken}`;
            await navigator.clipboard.writeText(url).catch(() => {});
            showToast('🔗 Đã copy URL: ' + url);
            return;
        }
        const res = await fetch(`/otp/${id}/share-token`, { method: 'POST' });
        const data = await res.json();
        if (res.ok) {
            const url = `${location.origin}/otp/share/${data.token}`;
            await navigator.clipboard.writeText(url).catch(() => {});
            showToast('🔗 Đã tạo & copy URL share');
        } else {
            showToast(data.message || 'Lỗi khi tạo share URL');
        }
    }

    function toggleSecret(id) {
        const span = document.getElementById(`otp-val-${id}`);
        const btn = document.getElementById(`otp-eye-${id}`);
        if (span.textContent === '••••••••••••••••') {
            span.textContent = span.dataset.secret;
            span.classList.replace('text-gray-400', 'text-gray-700');
            btn.textContent = '🙈';
        } else {
            span.textContent = '••••••••••••••••';
            span.classList.replace('text-gray-700', 'text-gray-400');
            btn.textContent = '👁';
        }
    }

    async function addOtp() {
        const name = document.getElementById('otp-new-name').value.trim();
        const value = document.getElementById('otp-new-value').value.trim();
        if (!name || !value) { showToast('Vui lòng nhập đầy đủ Name và Secret'); return; }
        const res = await fetch('/settings/otp/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, value })
        });
        const data = await res.json();
        if (res.ok) {
            showToast(data.message || 'Đã lưu');
            const newId = data.id;
            const tbody = document.getElementById('otp-table-body');
            document.getElementById('otp-empty-row')?.remove();
            const partialSecret = value.replace(/\s/g, '').substring(0, 4) + '••••••••••••';
            tbody.insertAdjacentHTML('beforeend', `
                <tr class="border-t border-gray-100" id="otp-row-${newId}">
                    <td class="px-4 py-3 font-medium text-gray-700">${name}</td>
                    <td class="px-4 py-3 font-mono text-gray-500">${partialSecret}</td>
                </tr>
            `);
            document.getElementById('otp-new-name').value = '';
            document.getElementById('otp-new-value').value = '';
        } else {
            showToast(data.message || 'Có lỗi xảy ra');
        }
    }

    async function deleteOtp(id) {
        if (!confirm('Xóa OTP secret này?')) return;
        const res = await fetch(`/settings/otp/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (res.ok) { document.getElementById(`otp-row-${id}`)?.remove(); showToast(data.message || 'Đã xóa'); }
        else showToast(data.message || 'Có lỗi xảy ra');
    }
</script>
